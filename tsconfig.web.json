{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "rootDir": "web",
    "outDir": "dist/web",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strict": false
  },
  "include": ["web/**/*.ts"]
}
